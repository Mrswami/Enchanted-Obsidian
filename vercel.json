{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "w2w-sync/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/cron/(.*)",
      "dest": "w2w-sync/server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "w2w-sync/server.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "w2w-sync/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 * * * *"
    }
  ]
}
